{
  "name": "travel-app-backend",
  "version": "0.1.0",
  "description": "Backend API for travel planning application",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "TS_CONFIG_PATH=dist/tsconfig.json node -r tsconfig-paths/register dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.0",
    "mongoose": "^7.5.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "axios": "^1.6.0",
    "google-auth-library": "^9.0.0",
    "googleapis": "^118.0.0",
    "zod": "^3.22.0",
    "winston": "^3.10.0",
    "express-rate-limit": "^7.0.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "tsx": "^3.14.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  }
}
